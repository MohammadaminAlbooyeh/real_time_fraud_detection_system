# Application
APP_NAME="Fraud Detection API"
APP_VERSION="0.1.0"
DEBUG=false
API_V1_PREFIX="/api/v1"
HOST="0.0.0.0"
PORT=8000

# Database (PostgreSQL)
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/fraud_detection"
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30

# Redis
REDIS_URL="redis://localhost:6379/0"
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5

# Kafka (Optional - using Redis Streams as alternative)
KAFKA_BOOTSTRAP_SERVERS="localhost:9092"
KAFKA_TRANSACTIONS_TOPIC="transactions"
KAFKA_ALERTS_TOPIC="alerts"
KAFKA_CONSUMER_GROUP="fraud-detector"

# ML Models
MODEL_PATH="/app/models/fraud_model.onnx"
MODEL_VERSION="1.0.0"
MODEL_THRESHOLD=0.5
MLFLOW_TRACKING_URI="http://localhost:5000"
MLFLOW_EXPERIMENT_NAME="fraud-detection"

# Feature Engineering
FEATURE_WINDOW_HOURS=24
VELOCITY_WINDOW_MINUTES=60
USER_PROFILE_TTL=86400

# Rule Engine
RULE_VELOCITY_TX_COUNT_THRESHOLD=10
RULE_VELOCITY_AMOUNT_THRESHOLD=10000.0
RULE_HIGH_RISK_COUNTRIES="CN,RU,KP,IR,SY"
RULE_IMPOSSIBLE_TRAVEL_KM_PER_HOUR=1000.0
RULE_NEW_DEVICE_THRESHOLD_HOURS=24
RULE_ROUND_AMOUNT_THRESHOLD=100.0

# Alerting
ALERT_WEBSOCKET_ENABLED=true
ALERT_EMAIL_ENABLED=false
ALERT_WEBHOOK_URL=""
ALERT_DEDUP_WINDOW_MINUTES=60

# WebSocket
WS_HEARTBEAT_INTERVAL=30
WS_MAX_CONNECTIONS=10000

# Security
SECRET_KEY="your-super-secret-key-change-in-production-min-32-chars"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS="http://localhost:3000,http://localhost:5173"

# Logging
LOG_LEVEL="INFO"
LOG_FORMAT="json"

# Monitoring
PROMETHEUS_METRICS_ENABLED=true
METRICS_PORT=9090